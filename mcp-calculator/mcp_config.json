{
  "mcpServers": {
    "local-robot-controller": {
      "type": "stdio",
      "command": "python",
      "args": ["robot_mcp_server.py"],
      "env": {
        "ROBOT_IP": "127.0.0.1",
        "ROBOT_PORT": "9000",
        "ROBOT_TIMEOUT": "5"
      }
    },
    "remote-sse-server": {
      "type": "sse",
      "url": "https://api.example.com/sse",
      "disabled": true
    },
    "remote-http-server": {
      "type": "http",
      "url": "https://api.example.com/mcp",
      "disabled": true
    }
  }
}
